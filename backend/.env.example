# Copy this to backend/.env (git-ignored) and fill in real values.
# docker compose automatically loads backend/.env when you run `up` from
# this directory.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional, only for short-lived role creds (SSO / STS).
# AWS_SESSION_TOKEN=

# Dev tuning (optional).
LOG_LEVEL=INFO
OCR_CONCURRENCY=8
OCR_MIN_CONFIDENCE=10
OCR_FUZZY_THRESHOLD=0.82
