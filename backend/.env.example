# Copy this to backend/.env (git-ignored) and fill in real values.
# docker compose automatically loads backend/.env when you run `up` from
# this directory.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional, only for short-lived role creds (SSO / STS).
# AWS_SESSION_TOKEN=

# Dev tuning (optional).
LOG_LEVEL=INFO
OCR_CONCURRENCY=8
OCR_MIN_CONFIDENCE=10
OCR_FUZZY_THRESHOLD=0.82

# Backtracking second pass (optional).
# Fraction of the hit's bbox to expand by on each side when searching
# the previous frame for a partial of the query.
BACKTRACK_SPATIAL_MARGIN=0.5
# Reject candidate partials shorter than this many chars (after normalizing).
BACKTRACK_MIN_PARTIAL_CHARS=2
# Hit correspondence threshold: two hits are "the same text that moved" if
# their normalized centers are within this distance.
BACKTRACK_LINK_CENTER_DIST=0.08
# SequenceMatcher ratio floor for substring/fuzzy acceptance.
BACKTRACK_FUZZY_THRESHOLD=0.82
